// @version=6
// Order Flow Suite — VWAP + Volume Profile (FRVP) + FVG + Delta proxy + Signals
//
// HONEST SCOPE
//   Pine has no access to real order flow (DOM / footprint / true bid-ask delta).
//   "Delta" and "CVD" here are derived from OHLCV using the standard
//   close-position-in-range estimator. On feeds without real volume
//   (e.g. some XAUUSD CFD feeds), volume = tick volume.
//
// FEATURES
//   - Anchored VWAP (session / week / month) with ±N stdev bands
//   - Fair Value Gap detection (3-bar) with mitigation tracking
//   - Fixed-range Volume Profile over last N bars: POC, VAH, VAL
//   - Estimated volume delta and CVD
//   - Confluence-based long/short signals
//   - ATR-based TP/SL lines drawn from each signal
//
// WORKS ON: XAUUSD, all crypto pairs, any symbol Pine can plot.

indicator("Order Flow Suite — VWAP/FVG/FRVP/Delta", shorttitle="OFS", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grpVwap   = "VWAP"
vwapAnchor = input.string("Session", "Anchor", options=["Session","Week","Month"], group=grpVwap)
showVwap   = input.bool(true,  "Show VWAP",  group=grpVwap)
showBands  = input.bool(true,  "Show Bands", group=grpVwap)
bandMult1  = input.float(1.0,  "Band 1 stdev", step=0.1, group=grpVwap)
bandMult2  = input.float(2.0,  "Band 2 stdev", step=0.1, group=grpVwap)

grpFvg    = "Fair Value Gaps"
showFvg   = input.bool(true, "Show FVGs", group=grpFvg)
fvgLookback = input.int(200, "Max FVGs tracked", minval=10, maxval=500, group=grpFvg)
mitigateOnTouch = input.bool(true, "Mitigate on wick touch", group=grpFvg)

grpVp     = "Volume Profile (FRVP)"
showVp    = input.bool(true, "Show Profile", group=grpVp)
vpBars    = input.int(200, "Lookback bars", minval=20, maxval=2000, group=grpVp)
vpRows    = input.int(50,  "Rows", minval=10, maxval=200, group=grpVp)
vaPct     = input.float(70.0, "Value Area %", minval=50, maxval=95, step=1, group=grpVp) / 100.0
vpRight   = input.int(30,  "Profile width (bars right)", minval=5, maxval=200, group=grpVp)

grpDelta  = "Delta (proxy)"
showCvd   = input.bool(false, "Plot CVD in separate pane (use add to chart)", group=grpDelta)
deltaLen  = input.int(20, "Delta SMA length", minval=2, maxval=200, group=grpDelta)

grpSig    = "Signals"
useVwapBias = input.bool(true,  "Require side of VWAP", group=grpSig)
useFvgConf  = input.bool(true,  "Require recent unmitigated FVG", group=grpSig)
useVpConf   = input.bool(true,  "Require price near POC/VAH/VAL", group=grpSig)
useDeltaConf= input.bool(true,  "Require delta confirmation", group=grpSig)
proximityAtr= input.float(0.5,  "Proximity to profile level (ATR)", step=0.1, group=grpSig)

grpRisk   = "Risk / Targets"
atrLen    = input.int(14,  "ATR length", minval=2, group=grpRisk)
slMult    = input.float(1.5, "SL = ATR ×", step=0.1, group=grpRisk)
tpMult    = input.float(2.5, "TP = ATR ×", step=0.1, group=grpRisk)
showRR    = input.bool(true, "Draw TP/SL lines on signal", group=grpRisk)

// ─── ANCHORED VWAP + BANDS ──────────────────────────────────────────────────
anchorChange = vwapAnchor == "Session" ? ta.change(time("D")) != 0 :
               vwapAnchor == "Week"    ? ta.change(time("W")) != 0 :
                                          ta.change(time("M")) != 0

var float sumPV  = 0.0
var float sumV   = 0.0
var float sumPV2 = 0.0
if anchorChange or bar_index == 0
    sumPV  := 0.0
    sumV   := 0.0
    sumPV2 := 0.0

typical = (high + low + close) / 3.0
v       = nz(volume, 1)
sumPV  += typical * v
sumV   += v
sumPV2 += typical * typical * v

vwap     = sumV > 0 ? sumPV / sumV : na
variance = sumV > 0 ? math.max(sumPV2 / sumV - vwap * vwap, 0) : 0
stdev    = math.sqrt(variance)

plot(showVwap  ? vwap : na, "VWAP", color=color.new(color.orange, 0), linewidth=2)
upper1 = vwap + bandMult1 * stdev
lower1 = vwap - bandMult1 * stdev
upper2 = vwap + bandMult2 * stdev
lower2 = vwap - bandMult2 * stdev
plot(showBands ? upper1 : na, "Upper 1σ", color=color.new(color.teal, 40))
plot(showBands ? lower1 : na, "Lower 1σ", color=color.new(color.teal, 40))
plot(showBands ? upper2 : na, "Upper 2σ", color=color.new(color.teal, 70))
plot(showBands ? lower2 : na, "Lower 2σ", color=color.new(color.teal, 70))

// ─── FAIR VALUE GAPS ────────────────────────────────────────────────────────
type Fvg
    box   bx
    float top
    float bot
    bool  bull
    bool  mitigated

var array<Fvg> fvgs = array.new<Fvg>()

bullFvg = low > high[2]
bearFvg = high < low[2]

if showFvg and bullFvg
    top = low
    bot = high[2]
    bx  = box.new(bar_index - 2, top, bar_index + 5, bot, border_color=color.new(color.green, 60), bgcolor=color.new(color.green, 85), extend=extend.right)
    array.push(fvgs, Fvg.new(bx, top, bot, true, false))

if showFvg and bearFvg
    top = low[2]
    bot = high
    bx  = box.new(bar_index - 2, top, bar_index + 5, bot, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 85), extend=extend.right)
    array.push(fvgs, Fvg.new(bx, top, bot, false, false))

// Trim and mitigate
if array.size(fvgs) > fvgLookback
    old = array.shift(fvgs)
    box.delete(old.bx)

if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.mitigated
            touched = mitigateOnTouch ?
                       (f.bull ? low  <= f.top and low  >= f.bot : high >= f.bot and high <= f.top) :
                       (f.bull ? close < f.bot : close > f.top)
            if touched
                f.mitigated := true
                box.set_bgcolor(f.bx, color.new(color.gray, 90))
                box.set_border_color(f.bx, color.new(color.gray, 70))
                box.set_extend(f.bx, extend.none)
                box.set_right(f.bx, bar_index)

// Most-recent unmitigated FVG queries
f_hasBullFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated
                found := true
                break
    found

f_hasBearFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated
                found := true
                break
    found

// ─── VOLUME PROFILE (FRVP) ──────────────────────────────────────────────────
var box   poc_line_box = na
var line  vah_line     = na
var line  val_line     = na
var array<box> vpBoxes = array.new<box>()

f_clearVpBoxes() =>
    if array.size(vpBoxes) > 0
        for i = 0 to array.size(vpBoxes) - 1
            box.delete(array.get(vpBoxes, i))
        array.clear(vpBoxes)

if showVp and barstate.islast
    f_clearVpBoxes()
    hh = ta.highest(high, vpBars)
    ll = ta.lowest(low,   vpBars)
    rng = hh - ll
    if rng > 0
        step = rng / vpRows
        bins = array.new<float>(vpRows, 0.0)
        for b = 0 to vpBars - 1
            hi = high[b]
            lo = low[b]
            vol = nz(volume[b], 1)
            barRng = hi - lo
            if barRng > 0
                slices = vol / vpRows
                for r = 0 to vpRows - 1
                    binLo = ll + r * step
                    binHi = binLo + step
                    overlap = math.max(0.0, math.min(hi, binHi) - math.max(lo, binLo))
                    if overlap > 0
                        share = overlap / barRng
                        array.set(bins, r, array.get(bins, r) + vol * share)
            else
                r = math.min(vpRows - 1, math.max(0, int((hi - ll) / step)))
                array.set(bins, r, array.get(bins, r) + vol)
        // POC
        pocIdx = 0
        pocVol = 0.0
        for r = 0 to vpRows - 1
            if array.get(bins, r) > pocVol
                pocVol := array.get(bins, r)
                pocIdx := r
        totalVol = array.sum(bins)
        targetVol = totalVol * vaPct
        accVol = pocVol
        lo_idx = pocIdx
        hi_idx = pocIdx
        while accVol < targetVol and (lo_idx > 0 or hi_idx < vpRows - 1)
            upVol = hi_idx < vpRows - 1 ? array.get(bins, hi_idx + 1) : -1.0
            dnVol = lo_idx > 0          ? array.get(bins, lo_idx - 1) : -1.0
            if upVol >= dnVol and upVol >= 0
                hi_idx += 1
                accVol += upVol
            else if dnVol >= 0
                lo_idx -= 1
                accVol += dnVol
            else
                break
        pocPrice = ll + (pocIdx + 0.5) * step
        vahPrice = ll + (hi_idx + 1)    * step
        valPrice = ll + lo_idx          * step
        // Draw rows
        maxBinVol = pocVol
        rightEdge = bar_index + vpRight
        for r = 0 to vpRows - 1
            v_r = array.get(bins, r)
            if v_r > 0
                width = int(vpRight * (v_r / maxBinVol))
                inVa = r >= lo_idx and r <= hi_idx
                col = r == pocIdx ? color.new(color.yellow, 30) : inVa ? color.new(color.blue, 70) : color.new(color.gray, 80)
                b = box.new(bar_index, ll + (r + 1) * step, bar_index + width, ll + r * step, border_color=na, bgcolor=col)
                array.push(vpBoxes, b)
        // POC / VAH / VAL labels
        label.new(rightEdge, pocPrice, "POC " + str.tostring(pocPrice, format.mintick), style=label.style_label_left, color=color.new(color.yellow, 20), textcolor=color.black, size=size.small)
        label.new(rightEdge, vahPrice, "VAH " + str.tostring(vahPrice, format.mintick), style=label.style_label_left, color=color.new(color.blue, 30),   textcolor=color.white, size=size.small)
        label.new(rightEdge, valPrice, "VAL " + str.tostring(valPrice, format.mintick), style=label.style_label_left, color=color.new(color.blue, 30),   textcolor=color.white, size=size.small)

// Persisted POC/VAH/VAL for signal logic (recomputed lightweight every bar)
f_profileLevels() =>
    hh = ta.highest(high, vpBars)
    ll = ta.lowest(low,   vpBars)
    rng = hh - ll
    pocPrice = float(na)
    vahPrice = float(na)
    valPrice = float(na)
    if rng > 0
        step = rng / vpRows
        bins = array.new<float>(vpRows, 0.0)
        for b = 0 to vpBars - 1
            hi = high[b]
            lo = low[b]
            vol = nz(volume[b], 1)
            barRng = hi - lo
            if barRng > 0
                for r = 0 to vpRows - 1
                    binLo = ll + r * step
                    binHi = binLo + step
                    overlap = math.max(0.0, math.min(hi, binHi) - math.max(lo, binLo))
                    if overlap > 0
                        share = overlap / barRng
                        array.set(bins, r, array.get(bins, r) + vol * share)
        pocIdx = 0
        pocVol = 0.0
        for r = 0 to vpRows - 1
            if array.get(bins, r) > pocVol
                pocVol := array.get(bins, r)
                pocIdx := r
        totalVol = array.sum(bins)
        targetVol = totalVol * vaPct
        accVol = pocVol
        lo_idx = pocIdx
        hi_idx = pocIdx
        while accVol < targetVol and (lo_idx > 0 or hi_idx < vpRows - 1)
            upVol = hi_idx < vpRows - 1 ? array.get(bins, hi_idx + 1) : -1.0
            dnVol = lo_idx > 0          ? array.get(bins, lo_idx - 1) : -1.0
            if upVol >= dnVol and upVol >= 0
                hi_idx += 1
                accVol += upVol
            else if dnVol >= 0
                lo_idx -= 1
                accVol += dnVol
            else
                break
        pocPrice := ll + (pocIdx + 0.5) * step
        vahPrice := ll + (hi_idx + 1)    * step
        valPrice := ll + lo_idx          * step
    [pocPrice, vahPrice, valPrice]

[pocP, vahP, valP] = f_profileLevels()

// ─── DELTA PROXY + CVD ──────────────────────────────────────────────────────
rng = high - low
buyFrac  = rng > 0 ? (close - low) / rng : 0.5
sellFrac = 1.0 - buyFrac
buyVol   = nz(volume, 1) * buyFrac
sellVol  = nz(volume, 1) * sellFrac
delta    = buyVol - sellVol
deltaSma = ta.sma(delta, deltaLen)
var float cvd = 0.0
cvd += delta

// ─── ATR ────────────────────────────────────────────────────────────────────
atr = ta.atr(atrLen)

// ─── SIGNAL CONFLUENCE ─────────────────────────────────────────────────────
nearLevel(level) => not na(level) and not na(atr) and math.abs(close - level) <= proximityAtr * atr
nearAnyVpUp   = nearLevel(valP) or nearLevel(pocP)
nearAnyVpDown = nearLevel(vahP) or nearLevel(pocP)

vwapBiasLong  = useVwapBias  ? close > vwap : true
vwapBiasShort = useVwapBias  ? close < vwap : true
fvgLong       = useFvgConf   ? f_hasBullFvg() : true
fvgShort      = useFvgConf   ? f_hasBearFvg() : true
vpLong        = useVpConf    ? nearAnyVpUp    : true
vpShort       = useVpConf    ? nearAnyVpDown  : true
deltaLong     = useDeltaConf ? deltaSma > 0   : true
deltaShort    = useDeltaConf ? deltaSma < 0   : true

bullTrigger = close > open and close > high[1]
bearTrigger = close < open and close < low[1]

longSig  = bullTrigger and vwapBiasLong  and fvgLong  and vpLong  and deltaLong
shortSig = bearTrigger and vwapBiasShort and fvgShort and vpShort and deltaShort

// Prevent overlapping back-to-back signals
var int lastSigBar = -1000
minBarsBetween = 3
longOk  = longSig  and bar_index - lastSigBar >= minBarsBetween
shortOk = shortSig and bar_index - lastSigBar >= minBarsBetween
if longOk or shortOk
    lastSigBar := bar_index

plotshape(longOk,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="LONG")
plotshape(shortOk, title="Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),   size=size.small, text="SHORT")

alertcondition(longOk,  title="Long signal",  message="OFS LONG {{ticker}} @ {{close}}")
alertcondition(shortOk, title="Short signal", message="OFS SHORT {{ticker}} @ {{close}}")

// ─── TP / SL LINES ──────────────────────────────────────────────────────────
if showRR and (longOk or shortOk)
    entry = close
    sl    = longOk ? entry - slMult * atr : entry + slMult * atr
    tp    = longOk ? entry + tpMult * atr : entry - tpMult * atr
    col_e = color.new(color.white,  0)
    col_t = color.new(color.green, 20)
    col_s = color.new(color.red,   20)
    line.new(bar_index, entry, bar_index + 20, entry, color=col_e, width=1, style=line.style_dashed)
    line.new(bar_index, tp,    bar_index + 20, tp,    color=col_t, width=2)
    line.new(bar_index, sl,    bar_index + 20, sl,    color=col_s, width=2)
    label.new(bar_index + 20, entry, "Entry " + str.tostring(entry, format.mintick), style=label.style_label_left, color=color.new(color.gray, 30), textcolor=color.white, size=size.small)
    label.new(bar_index + 20, tp,    "TP "    + str.tostring(tp,    format.mintick), style=label.style_label_left, color=col_t,                    textcolor=color.white, size=size.small)
    label.new(bar_index + 20, sl,    "SL "    + str.tostring(sl,    format.mintick), style=label.style_label_left, color=col_s,                    textcolor=color.white, size=size.small)

// ─── OPTIONAL: CVD plot (use Add Indicator to chart on separate pane) ──────
plot(showCvd ? cvd : na, "CVD (proxy)", color=color.new(color.purple, 0), display=display.data_window)
