// @version=6
// Order Flow Suite v4 — Real-Delta + Structure + FRVP + FVG
// ============================================================================
// REAL CALCULATIONS
//
// VWAP (anchored, TV-compatible):
//   vwap  = SUM(hlc3*vol) / SUM(vol),  stdev = sqrt(SUM(hlc3^2*vol)/SUM(vol) - vwap^2)
//
// VOLUME PROFILE (FRVP):
//   Each bar splits its volume across the price bins it intersects in
//   proportion to (overlap_height / bar_range_height).
//   POC = bin with max volume. VA = expand from POC (single-row or TV
//   two-row pair mode) until sum >= 70% of total.
//
// DELTA (order-flow proxy):
//   LTF (real):  for every 1m bar inside the current chart bar, sign its
//                volume by LTF close vs open and sum. This is the standard
//                approximation used by paid OF indicators.
//   Proxy:       volume * (2 * close_position_in_range - 1)
//
// TREND: HTF EMA (default 50 on 4H) + market-structure BOS from pivot H/L.
//
// SL (Structure):
//   long:  min(triggering FVG bottom, last pivot swing low, entry - ATR*slMult) - buf
//   short: mirror
//   The ATR floor prevents SL from being tighter than ATR distance.
//
// TP (Next level):
//   long:  nearest of {VAH, POC, VAL, swing high, opposite bear-FVG bottom} above entry
//   short: mirror
//
// VISUAL MAP
//   Orange line = VWAP, dotted = bands
//   Yellow line = POC,  Blue dashed = VAH/VAL, shaded box = Value Area
//   Green box   = bull FVG (LONG zone), Red box = bear FVG (SHORT zone)
//   Triangles   = signals; Entry/TP/SL drawn only for the CURRENT trade
//   Top-right   = live levels + trend readout
//
// HONEST SCOPE: Pine has no DOM/footprint/bid-ask. LTF aggregation is the
// closest possible to real delta. XAU on CFD feeds carries tick volume only.
// ============================================================================

indicator("Order Flow Suite v4", shorttitle="OFS v4", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// INPUTS
gView   = "Display"
compact     = input.bool(true,  "Compact mode (hide minor lines)", group=gView)
showTable   = input.bool(true,  "Show info table (top-right)",     group=gView)
extendLines = input.bool(true,  "Extend key levels across chart",  group=gView)

gVwap   = "VWAP"
showVwap    = input.bool(true,  "VWAP line",  group=gVwap)
showBands   = input.bool(true,  "VWAP bands", group=gVwap)
vwapAnchor  = input.string("Week", "Anchor", options=["Session","Week","Month","Year"], group=gVwap)
vwapSrc     = input.source(hlc3, "Source", group=gVwap)
bandMode    = input.string("Stdev (TV-compatible)", "Band calculation", options=["Stdev (TV-compatible)","ATR"], group=gVwap)
bandMult1   = input.float(1.0, "Band 1 multiplier", step=0.1, group=gVwap)
bandMult2   = input.float(2.0, "Band 2 multiplier", step=0.1, group=gVwap)
bandLen     = input.int(20, "ATR length (ATR mode only)", minval=2, group=gVwap)
colVwap     = input.color(color.orange, "VWAP color", group=gVwap)

gFvg    = "FVG (Entry Zones)"
showFvg     = input.bool(true,  "Show FVG zones", group=gFvg)
showMitig   = input.bool(false, "Show mitigated FVGs", group=gFvg)
maxFvg      = input.int(3, "Max active FVGs shown", minval=1, maxval=30, group=gFvg)
mitigMode   = input.string("Close", "Mitigation", options=["Wick","Close"], group=gFvg)
colBull     = input.color(color.new(#00c853, 70), "Bull FVG fill", group=gFvg)
colBear     = input.color(color.new(#d50000, 70), "Bear FVG fill", group=gFvg)

gVp     = "Volume Profile (FRVP)"
showVp      = input.bool(true, "Show profile", group=gVp)
vpMode      = input.string("Rolling lookback", "Profile mode", options=["Fixed Range","Rolling lookback","Visible range"], group=gVp)
vpStart     = input.time(timestamp("01 Jan 2026 00:00 +0000"), "Fixed range START", group=gVp)
vpEnd       = input.time(timestamp("01 Jan 2027 00:00 +0000"), "Fixed range END", group=gVp)
vpBars      = input.int(300, "Rolling lookback bars", minval=50, maxval=5000, group=gVp)
vpRows      = input.int(60, "Rows", minval=20, maxval=200, group=gVp)
vaPct       = input.float(70.0, "Value Area %", minval=50, maxval=95, step=1, group=gVp) / 100.0
vpExpansion = input.string("Single row", "VA expansion algorithm", options=["Single row","Two-row pair (TV)"], group=gVp)
showVpHist  = input.bool(true, "Show histogram bars", group=gVp)
vpHistSide  = input.string("Right", "Histogram side", options=["Right","Left"], group=gVp)
showVaFill  = input.bool(true, "Shade Value Area", group=gVp)
colPoc      = input.color(#ffd600, "POC color", group=gVp)
colVa       = input.color(#2962ff, "VAH/VAL color", group=gVp)

gDelta  = "Order Flow (Delta)"
deltaMode   = input.string("LTF (real)", "Delta source", options=["LTF (real)","Close-position (proxy)"], group=gDelta, tooltip="LTF (real): aggregates 1-minute bars inside current bar; sums +volume when LTF close>open, -volume otherwise. This is the closest Pine gets to true delta. Proxy: estimates from close position in candle range.")
ltfTF       = input.timeframe("1", "LTF timeframe (for real delta)", group=gDelta)
deltaLen    = input.int(20, "Delta SMA length", minval=2, group=gDelta)

gTrend  = "Trend Filter (HTF)"
useTrendFilter = input.bool(true, "Filter signals by HTF trend", group=gTrend, tooltip="Only allow longs when above HTF EMA and bullish structure; shorts when below and bearish.")
trendTF     = input.timeframe("240", "HTF for trend EMA (e.g. 240=4H)", group=gTrend)
trendLen    = input.int(50, "HTF EMA length", minval=5, group=gTrend)
useStructure= input.bool(true, "Also require market-structure direction (BOS)", group=gTrend)
pivotLen    = input.int(5, "Pivot lookback for swings", minval=2, group=gTrend)

gSig    = "Signals"
sigMode     = input.string("FVG retest (swing)", "Signal logic", options=["FVG retest (swing)","Breakout trigger"], group=gSig)
useVwapBias = input.bool(true,  "Require side of VWAP", group=gSig)
useVpConf   = input.bool(false, "Require near POC / VAH / VAL", group=gSig)
useDeltaConf= input.bool(false, "Require delta confirmation", group=gSig)
proxAtr     = input.float(0.75, "Level proximity (ATR x)", step=0.1, group=gSig)
cooldown    = input.int(5, "Min bars between signals", minval=1, group=gSig)

gRisk   = "Risk / Targets"
slLogic     = input.string("Structure", "SL logic", options=["Structure","ATR"], group=gRisk, tooltip="Structure: SL just beyond triggering FVG or recent swing. ATR: fixed ATR multiple.")
tpLogic     = input.string("Next level", "TP logic", options=["Next level","R-multiple","ATR"], group=gRisk, tooltip="Next level: nearest POC/VAH/VAL/opposite-FVG/swing in trade direction. R-multiple: TP = entry + R × SL distance.")
rMult       = input.float(2.0,  "R multiplier (for R-mode)", step=0.1, group=gRisk)
slBufferAtr = input.float(0.15, "SL buffer (×ATR) beyond structure", step=0.05, group=gRisk)
swingLen    = input.int(10,     "Swing lookback (bars)", minval=3, group=gRisk)
atrLen      = input.int(14,     "ATR length", minval=2, group=gRisk)
slMult      = input.float(1.5,  "SL = ATR × (ATR mode only)", step=0.1, group=gRisk)
tpMult      = input.float(2.5,  "TP = ATR × (ATR mode only)", step=0.1, group=gRisk)
rrExtend    = input.int(40,     "TP/SL extend bars", minval=10, maxval=400, group=gRisk)

// VWAP + BANDS
anchorReset = vwapAnchor == "Session" ? ta.change(time("D")) != 0 : vwapAnchor == "Week" ? ta.change(time("W")) != 0 : vwapAnchor == "Month" ? ta.change(time("M")) != 0 : ta.change(time("12M")) != 0

var float sPV  = 0.0
var float sV   = 0.0
var float sPV2 = 0.0
if anchorReset or bar_index == 0
    sPV  := 0.0
    sV   := 0.0
    sPV2 := 0.0

src_ = vwapSrc
v_   = nz(volume, 1)
sPV  += src_ * v_
sV   += v_
sPV2 += src_ * src_ * v_

vwap   = sV > 0 ? sPV / sV : na
varnce = sV > 0 ? math.max(sPV2 / sV - vwap * vwap, 0) : 0
sd     = math.sqrt(varnce)
atrBand = ta.atr(bandLen)
bandUnit = bandMode == "ATR" ? atrBand : sd
u1 = vwap + bandMult1 * bandUnit
l1 = vwap - bandMult1 * bandUnit
u2 = vwap + bandMult2 * bandUnit
l2 = vwap - bandMult2 * bandUnit

plot(showVwap                  ? vwap : na, "VWAP", color=colVwap, linewidth=2)
plot(showBands and not compact ? u1   : na, "+1",   color=color.new(colVwap, 55), style=plot.style_circles)
plot(showBands and not compact ? l1   : na, "-1",   color=color.new(colVwap, 55), style=plot.style_circles)
plot(showBands                 ? u2   : na, "+2",   color=color.new(colVwap, 70), style=plot.style_circles)
plot(showBands                 ? l2   : na, "-2",   color=color.new(colVwap, 70), style=plot.style_circles)

// FVG
type Fvg
    box   bx
    label lb
    float top
    float bot
    bool  bull
    bool  mitigated

var array<Fvg> fvgs = array.new<Fvg>()

bullFvg = low  > high[2]
bearFvg = high < low[2]

if showFvg and bullFvg
    fTop = low
    fBot = high[2]
    fBx  = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=color.new(#00c853, 0), border_width=1, bgcolor=colBull, extend=extend.right)
    fLb  = label.new(bar_index, (fTop + fBot) / 2.0, "LONG ZONE", style=label.style_label_left, color=color.new(#00c853, 30), textcolor=color.white, size=size.tiny)
    array.push(fvgs, Fvg.new(fBx, fLb, fTop, fBot, true, false))

if showFvg and bearFvg
    fTop = low[2]
    fBot = high
    fBx  = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=color.new(#d50000, 0), border_width=1, bgcolor=colBear, extend=extend.right)
    fLb  = label.new(bar_index, (fTop + fBot) / 2.0, "SHORT ZONE", style=label.style_label_left, color=color.new(#d50000, 30), textcolor=color.white, size=size.tiny)
    array.push(fvgs, Fvg.new(fBx, fLb, fTop, fBot, false, false))

if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.mitigated
            touched = mitigMode == "Wick" ? (f.bull ? low <= f.top : high >= f.bot) : (f.bull ? close < f.bot : close > f.top)
            if touched
                f.mitigated := true
                if showMitig
                    box.set_bgcolor(f.bx, color.new(color.gray, 88))
                    box.set_border_color(f.bx, color.new(color.gray, 70))
                    box.set_extend(f.bx, extend.none)
                    box.set_right(f.bx, bar_index)
                    label.set_text(f.lb, "mitigated")
                    label.set_color(f.lb, color.new(color.gray, 60))
                else
                    box.delete(f.bx)
                    label.delete(f.lb)

activeCount = 0
if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.mitigated
            activeCount += 1
            if activeCount > maxFvg
                box.delete(f.bx)
                label.delete(f.lb)
                array.remove(fvgs, i)

if barstate.islast and array.size(fvgs) > 0
    for i = 0 to array.size(fvgs) - 1
        f = array.get(fvgs, i)
        if not f.mitigated
            label.set_x(f.lb, bar_index + 2)
            label.set_y(f.lb, (f.top + f.bot) / 2.0)

f_hasBullFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated
                found := true
                break
    found

f_hasBearFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated
                found := true
                break
    found

// VOLUME PROFILE
var line  pocLn = na
var line  vahLn = na
var line  valLn = na
var label pocLb = na
var label vahLb = na
var label valLb = na
var box   vaFill = na
var array<box> vpBoxes = array.new<box>()
var float pocP = na
var float vahP = na
var float valP = na

f_clearVpBoxes() =>
    if array.size(vpBoxes) > 0
        for i = 0 to array.size(vpBoxes) - 1
            box.delete(array.get(vpBoxes, i))
        array.clear(vpBoxes)

f_resolveRange() =>
    int sbar = 0
    int ebar = bar_index
    msPerBar = timeframe.in_seconds() * 1000
    if vpMode == "Fixed Range"
        backStart = msPerBar > 0 ? int((time - vpStart) / msPerBar) : 0
        backEnd   = msPerBar > 0 ? int((time - vpEnd)   / msPerBar) : 0
        sbar := math.max(0, bar_index - math.max(0, backStart))
        ebar := math.min(bar_index, bar_index - math.max(0, backEnd))
        if ebar < sbar
            ebar := sbar
    else if vpMode == "Rolling lookback"
        sbar := math.max(0, bar_index - vpBars + 1)
        ebar := bar_index
    else
        lvt = chart.left_visible_bar_time
        rvt = chart.right_visible_bar_time
        backStart = msPerBar > 0 ? int((time - lvt) / msPerBar) : 0
        backEnd   = msPerBar > 0 ? int((time - rvt) / msPerBar) : 0
        sbar := math.max(0, bar_index - math.max(0, backStart))
        ebar := math.min(bar_index, bar_index - math.max(0, backEnd))
        if ebar < sbar
            ebar := sbar
    [sbar, ebar]

if barstate.islast and showVp
    f_clearVpBoxes()
    line.delete(pocLn)
    line.delete(vahLn)
    line.delete(valLn)
    label.delete(pocLb)
    label.delete(vahLb)
    label.delete(valLb)
    box.delete(vaFill)

    [sBar, eBar] = f_resolveRange()
    nBars = eBar - sBar + 1
    if nBars >= 2
        hh = high[bar_index - eBar]
        ll = low[bar_index - eBar]
        for k = 0 to nBars - 1
            off = bar_index - (sBar + k)
            hh := math.max(hh, high[off])
            ll := math.min(ll, low[off])
        rng = hh - ll
        if rng > 0
            step = rng / vpRows
            bins = array.new<float>(vpRows, 0.0)
            for k = 0 to nBars - 1
                off = bar_index - (sBar + k)
                hi  = high[off]
                lo  = low[off]
                vol = nz(volume[off], 1)
                barRng = hi - lo
                if barRng > 0
                    for r = 0 to vpRows - 1
                        binLo = ll + r * step
                        binHi = binLo + step
                        overlap = math.max(0.0, math.min(hi, binHi) - math.max(lo, binLo))
                        if overlap > 0
                            share = overlap / barRng
                            array.set(bins, r, array.get(bins, r) + vol * share)
                else
                    idx = math.min(vpRows - 1, math.max(0, int((hi - ll) / step)))
                    array.set(bins, idx, array.get(bins, idx) + vol)

            pocIdx = 0
            pocVol = 0.0
            for r = 0 to vpRows - 1
                if array.get(bins, r) > pocVol
                    pocVol := array.get(bins, r)
                    pocIdx := r

            totalVol = array.sum(bins)
            target   = totalVol * vaPct
            acc      = pocVol
            loI      = pocIdx
            hiI      = pocIdx
            if vpExpansion == "Two-row pair (TV)"
                while acc < target and (loI > 0 or hiI < vpRows - 1)
                    up1 = hiI < vpRows - 1 ? array.get(bins, hiI + 1) : 0.0
                    up2 = hiI < vpRows - 2 ? array.get(bins, hiI + 2) : 0.0
                    dn1 = loI > 0 ? array.get(bins, loI - 1) : 0.0
                    dn2 = loI > 1 ? array.get(bins, loI - 2) : 0.0
                    upPair = (hiI < vpRows - 1 ? up1 : -1.0) + (hiI < vpRows - 2 ? up2 : 0.0)
                    dnPair = (loI > 0 ? dn1 : -1.0) + (loI > 1 ? dn2 : 0.0)
                    if upPair >= dnPair and hiI < vpRows - 1
                        hiI += 1
                        acc += up1
                        if acc < target and hiI < vpRows - 1
                            hiI += 1
                            acc += up2
                    else if loI > 0
                        loI -= 1
                        acc += dn1
                        if acc < target and loI > 0
                            loI -= 1
                            acc += dn2
                    else
                        break
            else
                while acc < target and (loI > 0 or hiI < vpRows - 1)
                    upV = hiI < vpRows - 1 ? array.get(bins, hiI + 1) : -1.0
                    dnV = loI > 0 ? array.get(bins, loI - 1) : -1.0
                    if upV >= dnV and upV >= 0
                        hiI += 1
                        acc += upV
                    else if dnV >= 0
                        loI -= 1
                        acc += dnV
                    else
                        break

            pocP := ll + (pocIdx + 0.5) * step
            vahP := ll + (hiI + 1) * step
            valP := ll + loI * step

            leftX  = sBar
            rightX = math.min(eBar, bar_index)
            extendRight = extendLines and eBar >= bar_index - 1

            if showVaFill
                vaFill := box.new(leftX, vahP, rightX, valP, border_color=na, bgcolor=color.new(colPoc, 92), extend=extendRight ? extend.right : extend.none)

            xs = extendRight ? extend.right : extend.none
            pocLn := line.new(leftX, pocP, rightX, pocP, color=colPoc, width=2, extend=xs)
            vahLn := line.new(leftX, vahP, rightX, vahP, color=colVa, width=1, style=line.style_dashed, extend=xs)
            valLn := line.new(leftX, valP, rightX, valP, color=colVa, width=1, style=line.style_dashed, extend=xs)

            labelX = bar_index + 3
            pocLb := label.new(labelX, pocP, "POC " + str.tostring(pocP, format.mintick), style=label.style_label_left, color=colPoc, textcolor=color.black, size=size.small)
            vahLb := label.new(labelX, vahP, "VAH " + str.tostring(vahP, format.mintick), style=label.style_label_left, color=color.new(colVa, 20), textcolor=color.white, size=size.small)
            valLb := label.new(labelX, valP, "VAL " + str.tostring(valP, format.mintick), style=label.style_label_left, color=color.new(colVa, 20), textcolor=color.white, size=size.small)

            if showVpHist
                maxV = pocVol
                wMax = math.min(60, math.max(20, int(nBars * 0.1)))
                rightAnchor = math.min(math.max(rightX + 1, bar_index + 1), bar_index + 400 - wMax)
                anchorBar = vpHistSide == "Right" ? rightAnchor : leftX - 1
                for r = 0 to vpRows - 1
                    vr = array.get(bins, r)
                    if vr > 0
                        w   = int(wMax * (vr / maxV))
                        inVa = r >= loI and r <= hiI
                        col = r == pocIdx ? color.new(colPoc, 30) : inVa ? color.new(colVa, 75) : color.new(color.gray, 85)
                        x1 = vpHistSide == "Right" ? anchorBar : anchorBar - w
                        x2 = vpHistSide == "Right" ? anchorBar + w : anchorBar
                        b  = box.new(x1, ll + (r + 1) * step, x2, ll + r * step, border_color=na, bgcolor=col)
                        array.push(vpBoxes, b)

// DELTA — real (LTF aggregation) or proxy
// REAL: pull each 1m bar inside the current chart bar; assign its volume as
//       +buy if its close>open, -sell if close<open; sum to get bar delta.
//       This is the standard order-flow approximation used by paid indicators.
// PROXY: close-position-in-range (cheap but coarse).
float delta = na
if deltaMode == "LTF (real)"
    ltfSignedVol = request.security_lower_tf(syminfo.tickerid, ltfTF, (close > open ? 1.0 : close < open ? -1.0 : 0.0) * nz(volume, 0))
    delta := array.size(ltfSignedVol) > 0 ? array.sum(ltfSignedVol) : 0.0
else
    rng_  = high - low
    buyF  = rng_ > 0 ? (close - low) / rng_ : 0.5
    sellF = 1.0 - buyF
    delta := nz(volume, 1) * (buyF - sellF)
dSma = ta.sma(delta, deltaLen)
var float cvd = 0.0
cvd += delta

// HTF TREND + MARKET STRUCTURE
htfEma = request.security(syminfo.tickerid, trendTF, ta.ema(close, trendLen), barmerge.gaps_off, barmerge.lookahead_off)
htfBullEma = not na(htfEma) and close > htfEma
htfBearEma = not na(htfEma) and close < htfEma

// Pivot-based market structure (BOS)
phigh = ta.pivothigh(high, pivotLen, pivotLen)
plow  = ta.pivotlow(low,  pivotLen, pivotLen)
var float lastSwingHigh = na
var float lastSwingLow  = na
var int   structureBias = 0   // +1 bull, -1 bear, 0 unknown
if not na(phigh)
    lastSwingHigh := phigh
if not na(plow)
    lastSwingLow  := plow
// Break of structure
if not na(lastSwingHigh) and close > lastSwingHigh
    structureBias := 1
if not na(lastSwingLow) and close < lastSwingLow
    structureBias := -1

trendL = useTrendFilter ? (htfBullEma and (not useStructure or structureBias >= 0)) : true
trendS = useTrendFilter ? (htfBearEma and (not useStructure or structureBias <= 0)) : true

// ATR
atr = ta.atr(atrLen)

// Pre-compute series functions at global scope (Pine consistency requirement)
globalSwingHi = ta.highest(high, swingLen)
globalSwingLo = ta.lowest(low,  swingLen)

// SIGNALS
near(level) => not na(level) and not na(atr) and math.abs(close - level) <= proxAtr * atr
nearLong  = near(valP) or near(pocP)
nearShort = near(vahP) or near(pocP)

biasL  = useVwapBias  ? close > vwap : true
biasS  = useVwapBias  ? close < vwap : true
vpL    = useVpConf    ? nearLong  : true
vpS    = useVpConf    ? nearShort : true
dL     = useDeltaConf ? dSma > 0  : true
dS     = useDeltaConf ? dSma < 0  : true

f_retestBullFvg() =>
    bool hit = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated
                if low <= f.top and close > f.bot and close > open
                    hit := true
                    break
    hit

f_retestBearFvg() =>
    bool hit = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated
                if high >= f.bot and close < f.top and close < open
                    hit := true
                    break
    hit

retestL = f_retestBullFvg()
retestS = f_retestBearFvg()

trigL = close > open and close > high[1] and (f_hasBullFvg() or not useVpConf)
trigS = close < open and close < low[1] and (f_hasBearFvg() or not useVpConf)

isRetest = sigMode == "FVG retest (swing)"
longSig  = isRetest ? (retestL and biasL and vpL and dL and trendL) : (trigL and biasL and vpL and dL and trendL)
shortSig = isRetest ? (retestS and biasS and vpS and dS and trendS) : (trigS and biasS and vpS and dS and trendS)

var int lastSig = -1000
longOk  = longSig  and bar_index - lastSig >= cooldown
shortOk = shortSig and bar_index - lastSig >= cooldown
if longOk or shortOk
    lastSig := bar_index

plotshape(longOk,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=#00c853, size=size.normal, text="LONG",  textcolor=color.white)
plotshape(shortOk, title="Short", style=shape.triangledown, location=location.abovebar, color=#d50000, size=size.normal, text="SHORT", textcolor=color.white)

alertcondition(longOk,  title="Long signal",  message="OFS LONG {{ticker}} @ {{close}}")
alertcondition(shortOk, title="Short signal", message="OFS SHORT {{ticker}} @ {{close}}")

// TP / SL — only the most recent trade is shown
var line  tEntryLn = na
var line  tTpLn    = na
var line  tSlLn    = na
var label tEntryLb = na
var label tTpLb    = na
var label tSlLb    = na

// Helpers: get triggering FVG bounds (most recent unmitigated in direction)
f_trigFvgBot(bull) =>
    float v = na
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull == bull and not f.mitigated
                v := f.bot
                break
    v

f_trigFvgTop(bull) =>
    float v = na
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull == bull and not f.mitigated
                v := f.top
                break
    v

// Next structural target above/below current price (excluding entry zone itself)
f_nextLevelAbove(px, sh) =>
    float best = na
    if not na(vahP) and vahP > px
        best := na(best) ? vahP : math.min(best, vahP)
    if not na(pocP) and pocP > px
        best := na(best) ? pocP : math.min(best, pocP)
    if not na(valP) and valP > px
        best := na(best) ? valP : math.min(best, valP)
    if not na(sh) and sh > px
        best := na(best) ? sh : math.min(best, sh)
    if array.size(fvgs) > 0
        for i = 0 to array.size(fvgs) - 1
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated and f.bot > px
                best := na(best) ? f.bot : math.min(best, f.bot)
    best

f_nextLevelBelow(px, sl_) =>
    float best = na
    if not na(valP) and valP < px
        best := na(best) ? valP : math.max(best, valP)
    if not na(pocP) and pocP < px
        best := na(best) ? pocP : math.max(best, pocP)
    if not na(vahP) and vahP < px
        best := na(best) ? vahP : math.max(best, vahP)
    if not na(sl_) and sl_ < px
        best := na(best) ? sl_ : math.max(best, sl_)
    if array.size(fvgs) > 0
        for i = 0 to array.size(fvgs) - 1
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated and f.top < px
                best := na(best) ? f.top : math.max(best, f.top)
    best

// Pre-evaluate next-level at global scope for consistency
nextAbove = f_nextLevelAbove(close, globalSwingHi)
nextBelow = f_nextLevelBelow(close, globalSwingLo)

if longOk or shortOk
    line.delete(tEntryLn)
    line.delete(tTpLn)
    line.delete(tSlLn)
    label.delete(tEntryLb)
    label.delete(tTpLb)
    label.delete(tSlLb)
    entry = close
    buf   = slBufferAtr * atr

    // ---- SL ----
    // Structure SL: anchor beyond the lower-of {triggering FVG bottom, last
    // pivot swing low, ATR floor}. This sits past the level that actually
    // invalidates the setup, not at an arbitrary ATR distance.
    float sl = na
    if slLogic == "Structure"
        if longOk
            fvgFloor = f_trigFvgBot(true)
            swingPivot = na(lastSwingLow) ? globalSwingLo : lastSwingLow
            atrFloor   = entry - slMult * atr
            base = swingPivot
            if not na(fvgFloor)
                base := math.min(base, fvgFloor)
            base := math.min(base, atrFloor)
            sl := base - buf
        else
            fvgCeil = f_trigFvgTop(false)
            swingPivot = na(lastSwingHigh) ? globalSwingHi : lastSwingHigh
            atrCeil    = entry + slMult * atr
            base = swingPivot
            if not na(fvgCeil)
                base := math.max(base, fvgCeil)
            base := math.max(base, atrCeil)
            sl := base + buf
    else
        sl := longOk ? entry - slMult * atr : entry + slMult * atr

    // ---- TP ----
    float tp = na
    if tpLogic == "Next level"
        tp := longOk ? nextAbove : nextBelow
        if na(tp)
            // fallback to R-multiple
            rDist = math.abs(entry - sl)
            tp := longOk ? entry + rMult * rDist : entry - rMult * rDist
    else if tpLogic == "R-multiple"
        rDist = math.abs(entry - sl)
        tp := longOk ? entry + rMult * rDist : entry - rMult * rDist
    else
        tp := longOk ? entry + tpMult * atr : entry - tpMult * atr
    eCol  = color.new(color.white, 0)
    tCol  = color.new(#00c853, 0)
    sCol  = color.new(#d50000, 0)
    rExt  = math.min(rrExtend, 400)
    tEntryLn := line.new(bar_index, entry, bar_index + rExt, entry, color=eCol, width=1, style=line.style_dashed)
    tTpLn    := line.new(bar_index, tp,    bar_index + rExt, tp,    color=tCol, width=2)
    tSlLn    := line.new(bar_index, sl,    bar_index + rExt, sl,    color=sCol, width=2)
    tEntryLb := label.new(bar_index + rExt, entry, "Entry " + str.tostring(entry, format.mintick), style=label.style_label_left, color=color.new(color.gray, 20), textcolor=color.white, size=size.small)
    tTpLb    := label.new(bar_index + rExt, tp,    "TP "    + str.tostring(tp,    format.mintick), style=label.style_label_left, color=tCol, textcolor=color.white, size=size.small)
    tSlLb    := label.new(bar_index + rExt, sl,    "SL "    + str.tostring(sl,    format.mintick), style=label.style_label_left, color=sCol, textcolor=color.white, size=size.small)

// Auto-invalidate the displayed trade when price hits TP or SL
if not na(tEntryLn)
    eY = line.get_y1(tEntryLn)
    sY = line.get_y1(tSlLn)
    tY = line.get_y1(tTpLn)
    isLong = tY > eY
    hit = isLong ? (high >= tY or low <= sY) : (low <= tY or high >= sY)
    if hit
        line.delete(tEntryLn)
        line.delete(tTpLn)
        line.delete(tSlLn)
        label.delete(tEntryLb)
        label.delete(tTpLb)
        label.delete(tSlLb)
        tEntryLn := na
        tTpLn    := na
        tSlLn    := na
        tEntryLb := na
        tTpLb    := na
        tSlLb    := na

// INFO TABLE
var table t = table.new(position.top_right, 2, 11, frame_color=color.new(color.gray, 50), frame_width=1, border_color=color.new(color.gray, 70), border_width=1)
if showTable and barstate.islast
    table.cell(t, 0, 0, "Order Flow Suite v4", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(t, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(t, 0, 1, "Price",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(close, format.mintick), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "VWAP",   text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, na(vwap) ? "-" : str.tostring(vwap, format.mintick), text_color=colVwap, text_size=size.small)
    table.cell(t, 0, 3, "POC",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, na(pocP) ? "-" : str.tostring(pocP, format.mintick), text_color=colPoc, text_size=size.small)
    table.cell(t, 0, 4, "VAH",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 4, na(vahP) ? "-" : str.tostring(vahP, format.mintick), text_color=colVa, text_size=size.small)
    table.cell(t, 0, 5, "VAL",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, na(valP) ? "-" : str.tostring(valP, format.mintick), text_color=colVa, text_size=size.small)
    table.cell(t, 0, 6, "Delta",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(dSma, "#.##"), text_color=dSma >= 0 ? #00c853 : #d50000, text_size=size.small)
    table.cell(t, 0, 7, "CVD",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(cvd, "#"), text_color=cvd >= 0 ? #00c853 : #d50000, text_size=size.small)
    table.cell(t, 0, 8, "HTF EMA", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 8, na(htfEma) ? "-" : str.tostring(htfEma, format.mintick), text_color=htfBullEma ? #00c853 : htfBearEma ? #d50000 : color.gray, text_size=size.small)
    structureTxt = structureBias > 0 ? "BULL (BOS up)" : structureBias < 0 ? "BEAR (BOS dn)" : "neutral"
    table.cell(t, 0, 9, "Structure", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 9, structureTxt, text_color=structureBias > 0 ? #00c853 : structureBias < 0 ? #d50000 : color.gray, text_size=size.small)
    bias = na(vwap) ? "-" : (htfBullEma and structureBias >= 0) ? "LONG OK" : (htfBearEma and structureBias <= 0) ? "SHORT OK" : "—"
    table.cell(t, 0, 10, "Trade bias", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 10, bias, text_color=bias == "LONG OK" ? #00c853 : bias == "SHORT OK" ? #d50000 : color.gray, text_size=size.small)
