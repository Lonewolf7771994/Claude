// @version=6
// Order Flow Suite v5 — XAUUSD-tuned, non-repainting
// ============================================================================
// DESIGNED FOR XAUUSD across all timeframes (1m → D).
// Auto-tunes pivot, swing, trend-HTF, and risk parameters based on the
// current chart timeframe. The user only toggles features on/off.
//
// NON-REPAINT GUARANTEE
//   - All signals fire on barstate.isconfirmed (the close of the bar) and
//     are evaluated using values that are fixed at that point.
//   - HTF data uses lookahead_off + gaps_off.
//   - Pivot-based structure (BOS) is naturally non-repaint: a pivot only
//     becomes known pivotLen bars after it formed.
//   - TP/SL lines are anchored to the entry bar and only break-even is
//     adjusted forward — historical levels never change.
//
// REAL CALCULATIONS
//   VWAP    = SUM(hlc3*vol) / SUM(vol); bands = volume-weighted stdev
//   FRVP    = bar-volume distributed across price bins by (overlap/range);
//             POC = max-volume bin; VA = expand from POC until 70% reached
//   Delta   = sum of signed volume from 1m subbars (real OF approximation)
//   Trend   = HTF EMA(50) bias + market-structure BOS from pivots
//   Sweep   = wick takes prior swing low/high then bar closes back inside
//   Reclaim = close crosses back through VWAP after spending bars opposite
//
// SIGNALS (3 logics, combined)
//   1. FVG retest    : price wicks into unmitigated FVG and rejects
//   2. Liquidity sweep: stop-run wick, close back inside, in trend direction
//   3. VWAP reclaim  : close pierces VWAP from wrong side, in trend direction
//
// TP / SL
//   SL    = max-distance of {triggering FVG bound, last pivot swing, ATR floor}
//   TP1   = 1R (auto-move SL to break-even when TP1 hit)
//   TP2   = nearest structural level beyond TP1 (POC/VAH/VAL/opposite FVG)
//   TP3   = next structural level beyond TP2 OR 3R
// ============================================================================

indicator("Order Flow Suite v5 (XAU)", shorttitle="OFS v5", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ── INPUTS ──────────────────────────────────────────────────────────────────
gMain = "Main"
useAuto     = input.bool(true, "Auto-tune for timeframe (RECOMMENDED)", group=gMain, tooltip="Auto-computes pivot/swing/HTF/ATR lengths from current TF. Turn off to override.")
useFvg      = input.bool(true, "Use FVG retest signals", group=gMain)
useSweep    = input.bool(true, "Use liquidity sweep signals", group=gMain)
useReclaim  = input.bool(true, "Use VWAP reclaim signals", group=gMain)

gView = "Display"
showVwap    = input.bool(true,  "VWAP", group=gView)
showFvg     = input.bool(true,  "FVG zones (max 2)", group=gView)
showVp      = input.bool(true,  "FRVP (POC/VAH/VAL)", group=gView)
showTable   = input.bool(true,  "Info table (top-right)", group=gView)
showLabels  = input.bool(true,  "Signal labels", group=gView)

gFilters = "Filters"
useTrend    = input.bool(true,  "HTF trend filter (RECOMMENDED)", group=gFilters)
useDelta    = input.bool(true,  "Require delta confirmation", group=gFilters)
useVwapBias = input.bool(true,  "Require side of VWAP", group=gFilters)

gOverride = "Manual overrides (only used if auto-tune OFF)"
mPivotLen   = input.int(5,  "Pivot len", minval=2, group=gOverride)
mSwingLen   = input.int(10, "Swing lookback", minval=3, group=gOverride)
mTrendTF    = input.timeframe("240", "HTF trend TF", group=gOverride)
mAtrLen     = input.int(14, "ATR length", minval=2, group=gOverride)

// ── AUTO-TUNE BY TIMEFRAME ──────────────────────────────────────────────────
tfSec = timeframe.in_seconds(timeframe.period)
autoPivotLen = tfSec <= 60      ? 3  : tfSec <= 300    ? 4  : tfSec <= 900   ? 5  : tfSec <= 3600 ? 6  : tfSec <= 14400 ? 7  : 8
autoSwingLen = tfSec <= 60      ? 8  : tfSec <= 300    ? 10 : tfSec <= 900   ? 14 : tfSec <= 3600 ? 18 : tfSec <= 14400 ? 22 : 30
autoTrendTF  = tfSec <= 60      ? "15" : tfSec <= 300  ? "60" : tfSec <= 900 ? "240" : tfSec <= 3600 ? "240" : tfSec <= 14400 ? "D" : "W"
autoAtrLen   = 14
autoVpBars   = tfSec <= 60      ? 200 : tfSec <= 300   ? 240 : tfSec <= 900  ? 240 : tfSec <= 3600 ? 200 : tfSec <= 14400 ? 150 : 100

pivotLen = useAuto ? autoPivotLen : mPivotLen
swingLen = useAuto ? autoSwingLen : mSwingLen
trendTF  = useAuto ? autoTrendTF  : mTrendTF
atrLen   = useAuto ? autoAtrLen   : mAtrLen
vpBars   = autoVpBars

// XAU-tuned constants
slBufferAtr = 0.20
slMultFloor = 1.2
proxAtr     = 0.6
cooldown    = 4
maxFvg      = 2
deltaSmaLen = 14
trendLen    = 50
vpRows      = 50
vaPct       = 0.70

// ── VWAP (anchored Week — best for XAU swing across TFs) ────────────────────
anchorReset = ta.change(time("W")) != 0
var float sPV  = 0.0
var float sV   = 0.0
var float sPV2 = 0.0
if anchorReset or bar_index == 0
    sPV  := 0.0
    sV   := 0.0
    sPV2 := 0.0
src_ = hlc3
v_   = nz(volume, 1)
sPV  += src_ * v_
sV   += v_
sPV2 += src_ * src_ * v_
vwap   = sV > 0 ? sPV / sV : na
varnce = sV > 0 ? math.max(sPV2 / sV - vwap * vwap, 0) : 0
sd     = math.sqrt(varnce)
vwapU  = vwap + sd
vwapL  = vwap - sd

plot(showVwap ? vwap  : na, "VWAP",  color=color.new(color.orange, 0), linewidth=2)
plot(showVwap ? vwapU : na, "+1sd",  color=color.new(color.orange, 70), style=plot.style_circles)
plot(showVwap ? vwapL : na, "-1sd",  color=color.new(color.orange, 70), style=plot.style_circles)

// ── ATR ─────────────────────────────────────────────────────────────────────
atr = ta.atr(atrLen)

// ── DELTA (real, LTF aggregation) ───────────────────────────────────────────
ltfSignedVol = request.security_lower_tf(syminfo.tickerid, "1", (close > open ? 1.0 : close < open ? -1.0 : 0.0) * nz(volume, 0))
delta = array.size(ltfSignedVol) > 0 ? array.sum(ltfSignedVol) : 0.0
dSma  = ta.sma(delta, deltaSmaLen)
var float cvd = 0.0
cvd += delta

// ── HTF TREND ───────────────────────────────────────────────────────────────
htfEma = request.security(syminfo.tickerid, trendTF, ta.ema(close, trendLen), barmerge.gaps_off, barmerge.lookahead_off)
htfBull = not na(htfEma) and close > htfEma
htfBear = not na(htfEma) and close < htfEma

// ── MARKET STRUCTURE (pivots → BOS) ─────────────────────────────────────────
phigh = ta.pivothigh(high, pivotLen, pivotLen)
plow  = ta.pivotlow(low,  pivotLen, pivotLen)
var float lastSwingHigh = na
var float lastSwingLow  = na
var int   structureBias = 0
if not na(phigh)
    lastSwingHigh := phigh
if not na(plow)
    lastSwingLow  := plow
if not na(lastSwingHigh) and close > lastSwingHigh
    structureBias := 1
if not na(lastSwingLow) and close < lastSwingLow
    structureBias := -1

trendL = useTrend ? (htfBull and structureBias >= 0) : true
trendS = useTrend ? (htfBear and structureBias <= 0) : true

// ── FVG ─────────────────────────────────────────────────────────────────────
type Fvg
    box   bx
    label lb
    float top
    float bot
    bool  bull
    bool  mitigated

var array<Fvg> fvgs = array.new<Fvg>()

bullFvg = low  > high[2]
bearFvg = high < low[2]

if showFvg and bullFvg
    fTop = low
    fBot = high[2]
    fBx  = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=color.new(#00c853, 0), border_width=1, bgcolor=color.new(#00c853, 80), extend=extend.right)
    fLb  = label.new(bar_index, (fTop + fBot) / 2.0, "LONG", style=label.style_label_left, color=color.new(#00c853, 30), textcolor=color.white, size=size.tiny)
    array.push(fvgs, Fvg.new(fBx, fLb, fTop, fBot, true, false))

if showFvg and bearFvg
    fTop = low[2]
    fBot = high
    fBx  = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=color.new(#d50000, 0), border_width=1, bgcolor=color.new(#d50000, 80), extend=extend.right)
    fLb  = label.new(bar_index, (fTop + fBot) / 2.0, "SHORT", style=label.style_label_left, color=color.new(#d50000, 30), textcolor=color.white, size=size.tiny)
    array.push(fvgs, Fvg.new(fBx, fLb, fTop, fBot, false, false))

// Mitigation (close-through)
if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.mitigated
            touched = f.bull ? close < f.bot : close > f.top
            if touched
                f.mitigated := true
                box.delete(f.bx)
                label.delete(f.lb)

activeCount = 0
if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.mitigated
            activeCount += 1
            if activeCount > maxFvg
                box.delete(f.bx)
                label.delete(f.lb)
                array.remove(fvgs, i)

if barstate.islast and array.size(fvgs) > 0
    for i = 0 to array.size(fvgs) - 1
        f = array.get(fvgs, i)
        if not f.mitigated
            label.set_x(f.lb, bar_index + 2)
            label.set_y(f.lb, (f.top + f.bot) / 2.0)

// ── VOLUME PROFILE (rolling lookback, computed once on last bar) ────────────
var line  pocLn = na
var line  vahLn = na
var line  valLn = na
var label pocLb = na
var label vahLb = na
var label valLb = na
var box   vaFill = na
var float pocP = na
var float vahP = na
var float valP = na

if barstate.islast and showVp
    line.delete(pocLn)
    line.delete(vahLn)
    line.delete(valLn)
    label.delete(pocLb)
    label.delete(vahLb)
    label.delete(valLb)
    box.delete(vaFill)

    sBar = math.max(0, bar_index - vpBars + 1)
    eBar = bar_index
    nBars = eBar - sBar + 1
    if nBars >= 2
        hh = high[bar_index - eBar]
        ll = low[bar_index - eBar]
        for k = 0 to nBars - 1
            off = bar_index - (sBar + k)
            hh := math.max(hh, high[off])
            ll := math.min(ll, low[off])
        rng = hh - ll
        if rng > 0
            step = rng / vpRows
            bins = array.new<float>(vpRows, 0.0)
            for k = 0 to nBars - 1
                off = bar_index - (sBar + k)
                hi  = high[off]
                lo  = low[off]
                vol = nz(volume[off], 1)
                barRng = hi - lo
                if barRng > 0
                    for r = 0 to vpRows - 1
                        binLo = ll + r * step
                        binHi = binLo + step
                        overlap = math.max(0.0, math.min(hi, binHi) - math.max(lo, binLo))
                        if overlap > 0
                            array.set(bins, r, array.get(bins, r) + vol * (overlap / barRng))
                else
                    idx = math.min(vpRows - 1, math.max(0, int((hi - ll) / step)))
                    array.set(bins, idx, array.get(bins, idx) + vol)
            pocIdx = 0
            pocVol = 0.0
            for r = 0 to vpRows - 1
                if array.get(bins, r) > pocVol
                    pocVol := array.get(bins, r)
                    pocIdx := r
            totalVol = array.sum(bins)
            target   = totalVol * vaPct
            acc      = pocVol
            loI      = pocIdx
            hiI      = pocIdx
            while acc < target and (loI > 0 or hiI < vpRows - 1)
                upV = hiI < vpRows - 1 ? array.get(bins, hiI + 1) : -1.0
                dnV = loI > 0 ? array.get(bins, loI - 1) : -1.0
                if upV >= dnV and upV >= 0
                    hiI += 1
                    acc += upV
                else if dnV >= 0
                    loI -= 1
                    acc += dnV
                else
                    break
            pocP := ll + (pocIdx + 0.5) * step
            vahP := ll + (hiI + 1) * step
            valP := ll + loI * step
            vaFill := box.new(sBar, vahP, eBar, valP, border_color=na, bgcolor=color.new(#ffd600, 92), extend=extend.right)
            pocLn := line.new(sBar, pocP, eBar, pocP, color=color.new(#ffd600, 0), width=2, extend=extend.right)
            vahLn := line.new(sBar, vahP, eBar, vahP, color=color.new(#2962ff, 0), width=1, style=line.style_dashed, extend=extend.right)
            valLn := line.new(sBar, valP, eBar, valP, color=color.new(#2962ff, 0), width=1, style=line.style_dashed, extend=extend.right)
            labelX = bar_index + 3
            pocLb := label.new(labelX, pocP, "POC " + str.tostring(pocP, format.mintick), style=label.style_label_left, color=color.new(#ffd600, 0), textcolor=color.black, size=size.small)
            vahLb := label.new(labelX, vahP, "VAH " + str.tostring(vahP, format.mintick), style=label.style_label_left, color=color.new(#2962ff, 20), textcolor=color.white, size=size.small)
            valLb := label.new(labelX, valP, "VAL " + str.tostring(valP, format.mintick), style=label.style_label_left, color=color.new(#2962ff, 20), textcolor=color.white, size=size.small)

// ── GLOBAL HELPERS ──────────────────────────────────────────────────────────
globalSwingHi = ta.highest(high, swingLen)
globalSwingLo = ta.lowest(low,  swingLen)

f_hasBullFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated
                found := true
                break
    found

f_hasBearFvg() =>
    bool found = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated
                found := true
                break
    found

f_trigFvgBot(bull) =>
    float v = na
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull == bull and not f.mitigated
                v := f.bot
                break
    v

f_trigFvgTop(bull) =>
    float v = na
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull == bull and not f.mitigated
                v := f.top
                break
    v

f_retestBullFvg() =>
    bool hit = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated
                if low <= f.top and close > f.bot and close > open
                    hit := true
                    break
    hit

f_retestBearFvg() =>
    bool hit = false
    if array.size(fvgs) > 0
        for i = array.size(fvgs) - 1 to 0
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated
                if high >= f.bot and close < f.top and close < open
                    hit := true
                    break
    hit

f_nextAbove(px) =>
    float best = na
    if not na(vahP) and vahP > px
        best := na(best) ? vahP : math.min(best, vahP)
    if not na(pocP) and pocP > px
        best := na(best) ? pocP : math.min(best, pocP)
    if not na(valP) and valP > px
        best := na(best) ? valP : math.min(best, valP)
    if not na(globalSwingHi) and globalSwingHi > px
        best := na(best) ? globalSwingHi : math.min(best, globalSwingHi)
    if array.size(fvgs) > 0
        for i = 0 to array.size(fvgs) - 1
            f = array.get(fvgs, i)
            if not f.bull and not f.mitigated and f.bot > px
                best := na(best) ? f.bot : math.min(best, f.bot)
    best

f_nextBelow(px) =>
    float best = na
    if not na(valP) and valP < px
        best := na(best) ? valP : math.max(best, valP)
    if not na(pocP) and pocP < px
        best := na(best) ? pocP : math.max(best, pocP)
    if not na(vahP) and vahP < px
        best := na(best) ? vahP : math.max(best, vahP)
    if not na(globalSwingLo) and globalSwingLo < px
        best := na(best) ? globalSwingLo : math.max(best, globalSwingLo)
    if array.size(fvgs) > 0
        for i = 0 to array.size(fvgs) - 1
            f = array.get(fvgs, i)
            if f.bull and not f.mitigated and f.top < px
                best := na(best) ? f.top : math.max(best, f.top)
    best

// Pre-compute at global scope (no-repaint hygiene)
nextAbove1 = f_nextAbove(close)
nextBelow1 = f_nextBelow(close)

// ── SIGNAL COMPONENTS ───────────────────────────────────────────────────────
biasL = useVwapBias ? close > vwap : true
biasS = useVwapBias ? close < vwap : true
dL    = useDelta    ? dSma > 0 : true
dS    = useDelta    ? dSma < 0 : true

// FVG retest
retestL = useFvg and f_retestBullFvg()
retestS = useFvg and f_retestBearFvg()

// Liquidity sweep: prior swing taken out by wick, but close back inside
sweepLong  = useSweep and not na(lastSwingLow)  and low  < lastSwingLow  and close > lastSwingLow  and close > open
sweepShort = useSweep and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh and close < open

// VWAP reclaim: was below for N bars, now closes above (and reverse)
var int barsBelowVwap = 0
var int barsAboveVwap = 0
barsBelowVwap := close < vwap ? barsBelowVwap + 1 : 0
barsAboveVwap := close > vwap ? barsAboveVwap + 1 : 0
reclaimLong  = useReclaim and ta.crossover(close, vwap)  and barsBelowVwap[1] >= 3
reclaimShort = useReclaim and ta.crossunder(close, vwap) and barsAboveVwap[1] >= 3

// Combine (any one of the three triggers, with filters)
rawLong  = (retestL or sweepLong or reclaimLong)   and biasL and dL and trendL
rawShort = (retestS or sweepShort or reclaimShort) and biasS and dS and trendS

// Non-repaint: only finalize on bar close
confirmed = barstate.isconfirmed
var int lastSig = -10000
longOk  = rawLong  and confirmed and bar_index - lastSig >= cooldown
shortOk = rawShort and confirmed and bar_index - lastSig >= cooldown
if longOk or shortOk
    lastSig := bar_index

// Signal source tag (for label)
sigTag(isLong) =>
    string tag = ""
    if isLong
        tag := retestL ? "FVG" : sweepLong ? "SWEEP" : "RECLAIM"
    else
        tag := retestS ? "FVG" : sweepShort ? "SWEEP" : "RECLAIM"
    tag

plotshape(longOk and showLabels,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=#00c853, size=size.normal, text="LONG", textcolor=color.white)
plotshape(shortOk and showLabels, title="Short", style=shape.triangledown, location=location.abovebar, color=#d50000, size=size.normal, text="SHORT", textcolor=color.white)

alertcondition(longOk,  title="Long signal",  message="OFS LONG {{ticker}} @ {{close}}")
alertcondition(shortOk, title="Short signal", message="OFS SHORT {{ticker}} @ {{close}}")

// ── TRADE MANAGEMENT (current trade only, with TP1/TP2/TP3 + BE) ────────────
var line  tEntryLn = na
var line  tSlLn    = na
var line  tTp1Ln   = na
var line  tTp2Ln   = na
var line  tTp3Ln   = na
var label tEntryLb = na
var label tSlLb    = na
var label tTp1Lb   = na
var label tTp2Lb   = na
var label tTp3Lb   = na
var float tEntry   = na
var float tSl      = na
var float tSlOrig  = na
var float tTp1     = na
var float tTp2     = na
var float tTp3     = na
var bool  tIsLong  = false
var bool  tBeMoved = false
var bool  tTp1Hit  = false
var bool  tTp2Hit  = false

f_clearTrade() =>
    line.delete(tEntryLn)
    line.delete(tSlLn)
    line.delete(tTp1Ln)
    line.delete(tTp2Ln)
    line.delete(tTp3Ln)
    label.delete(tEntryLb)
    label.delete(tSlLb)
    label.delete(tTp1Lb)
    label.delete(tTp2Lb)
    label.delete(tTp3Lb)

if longOk or shortOk
    f_clearTrade()
    tIsLong  := longOk
    tBeMoved := false
    tTp1Hit  := false
    tTp2Hit  := false
    tEntry   := close
    buf      = slBufferAtr * atr

    // SL — widest of structure-based anchors
    if tIsLong
        fvgFloor   = f_trigFvgBot(true)
        swingPivot = na(lastSwingLow) ? globalSwingLo : lastSwingLow
        atrFloor   = tEntry - slMultFloor * atr
        base = swingPivot
        if not na(fvgFloor)
            base := math.min(base, fvgFloor)
        base := math.min(base, atrFloor)
        tSl := base - buf
    else
        fvgCeil    = f_trigFvgTop(false)
        swingPivot = na(lastSwingHigh) ? globalSwingHi : lastSwingHigh
        atrCeil    = tEntry + slMultFloor * atr
        base = swingPivot
        if not na(fvgCeil)
            base := math.max(base, fvgCeil)
        base := math.max(base, atrCeil)
        tSl := base + buf
    tSlOrig := tSl
    rDist   = math.abs(tEntry - tSl)

    // TP1 = 1R (fixed). TP2 = next structural level beyond TP1. TP3 = next beyond TP2, or 3R fallback.
    if tIsLong
        tTp1 := tEntry + 1.0 * rDist
        n2   = f_nextAbove(tTp1)
        tTp2 := not na(n2) ? n2 : tEntry + 2.0 * rDist
        n3   = f_nextAbove(tTp2)
        tTp3 := not na(n3) ? n3 : tEntry + 3.0 * rDist
    else
        tTp1 := tEntry - 1.0 * rDist
        n2   = f_nextBelow(tTp1)
        tTp2 := not na(n2) ? n2 : tEntry - 2.0 * rDist
        n3   = f_nextBelow(tTp2)
        tTp3 := not na(n3) ? n3 : tEntry - 3.0 * rDist

    // Draw lines
    eCol = color.new(color.white, 0)
    tCol = color.new(#00c853, 0)
    sCol = color.new(#d50000, 0)
    rExt = 40
    tEntryLn := line.new(bar_index, tEntry, bar_index + rExt, tEntry, color=eCol, width=1, style=line.style_dashed)
    tSlLn    := line.new(bar_index, tSl,    bar_index + rExt, tSl,    color=sCol, width=2)
    tTp1Ln   := line.new(bar_index, tTp1,   bar_index + rExt, tTp1,   color=color.new(tCol, 50), width=1)
    tTp2Ln   := line.new(bar_index, tTp2,   bar_index + rExt, tTp2,   color=color.new(tCol, 25), width=1)
    tTp3Ln   := line.new(bar_index, tTp3,   bar_index + rExt, tTp3,   color=tCol, width=2)
    tEntryLb := label.new(bar_index + rExt, tEntry, "Entry " + str.tostring(tEntry, format.mintick),                   style=label.style_label_left, color=color.new(color.gray, 20), textcolor=color.white, size=size.small)
    tSlLb    := label.new(bar_index + rExt, tSl,    "SL "    + str.tostring(tSl,    format.mintick) + " (" + sigTag(tIsLong) + ")", style=label.style_label_left, color=sCol, textcolor=color.white, size=size.small)
    tTp1Lb   := label.new(bar_index + rExt, tTp1,   "TP1 "   + str.tostring(tTp1,   format.mintick) + " (1R)",        style=label.style_label_left, color=color.new(tCol, 50), textcolor=color.white, size=size.small)
    tTp2Lb   := label.new(bar_index + rExt, tTp2,   "TP2 "   + str.tostring(tTp2,   format.mintick),                   style=label.style_label_left, color=color.new(tCol, 25), textcolor=color.white, size=size.small)
    tTp3Lb   := label.new(bar_index + rExt, tTp3,   "TP3 "   + str.tostring(tTp3,   format.mintick),                   style=label.style_label_left, color=tCol, textcolor=color.white, size=size.small)

// Manage open trade: TP hits, break-even, full exit on SL/TP3
if not na(tEntryLn)
    // TP1 hit → move SL to entry (break-even)
    if not tTp1Hit
        hit1 = tIsLong ? high >= tTp1 : low <= tTp1
        if hit1
            tTp1Hit  := true
            tSl      := tEntry
            tBeMoved := true
            line.set_y1(tSlLn, tEntry)
            line.set_y2(tSlLn, tEntry)
            label.set_y(tSlLb, tEntry)
            label.set_text(tSlLb, "SL " + str.tostring(tEntry, format.mintick) + " (BE)")
            line.set_color(tTp1Ln, color.new(color.gray, 60))
            label.set_text(tTp1Lb, "TP1 hit")
    // TP2 hit → grey it out
    if tTp1Hit and not tTp2Hit
        hit2 = tIsLong ? high >= tTp2 : low <= tTp2
        if hit2
            tTp2Hit := true
            line.set_color(tTp2Ln, color.new(color.gray, 60))
            label.set_text(tTp2Lb, "TP2 hit")
    // SL hit or TP3 hit → close trade
    slHit = tIsLong ? low  <= tSl  : high >= tSl
    tp3Hit = tIsLong ? high >= tTp3 : low  <= tTp3
    if slHit or tp3Hit
        f_clearTrade()
        tEntryLn := na
        tSlLn    := na
        tTp1Ln   := na
        tTp2Ln   := na
        tTp3Ln   := na
        tEntryLb := na
        tSlLb    := na
        tTp1Lb   := na
        tTp2Lb   := na
        tTp3Lb   := na

// ── INFO TABLE ──────────────────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 11, frame_color=color.new(color.gray, 50), frame_width=1, border_color=color.new(color.gray, 70), border_width=1)
if showTable and barstate.islast
    table.cell(t, 0, 0, "OFS v5 — " + timeframe.period, text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(t, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(t, 0, 1, "Price",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(close, format.mintick), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "VWAP",   text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 2, na(vwap) ? "-" : str.tostring(vwap, format.mintick), text_color=color.orange, text_size=size.small)
    table.cell(t, 0, 3, "POC",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 3, na(pocP) ? "-" : str.tostring(pocP, format.mintick), text_color=#ffd600, text_size=size.small)
    table.cell(t, 0, 4, "VAH",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 4, na(vahP) ? "-" : str.tostring(vahP, format.mintick), text_color=#2962ff, text_size=size.small)
    table.cell(t, 0, 5, "VAL",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 5, na(valP) ? "-" : str.tostring(valP, format.mintick), text_color=#2962ff, text_size=size.small)
    table.cell(t, 0, 6, "Delta",  text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(dSma, "#"), text_color=dSma >= 0 ? #00c853 : #d50000, text_size=size.small)
    table.cell(t, 0, 7, "CVD",    text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(cvd, "#"), text_color=cvd >= 0 ? #00c853 : #d50000, text_size=size.small)
    table.cell(t, 0, 8, "HTF " + trendTF + " EMA", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 8, na(htfEma) ? "-" : str.tostring(htfEma, format.mintick), text_color=htfBull ? #00c853 : htfBear ? #d50000 : color.gray, text_size=size.small)
    structureTxt = structureBias > 0 ? "BULL (BOS up)" : structureBias < 0 ? "BEAR (BOS dn)" : "neutral"
    table.cell(t, 0, 9, "Structure", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 9, structureTxt, text_color=structureBias > 0 ? #00c853 : structureBias < 0 ? #d50000 : color.gray, text_size=size.small)
    bias = (htfBull and structureBias >= 0) ? "LONG OK" : (htfBear and structureBias <= 0) ? "SHORT OK" : "wait"
    table.cell(t, 0, 10, "Bias", text_color=color.silver, text_size=size.small)
    table.cell(t, 1, 10, bias, text_color=bias == "LONG OK" ? #00c853 : bias == "SHORT OK" ? #d50000 : color.gray, text_size=size.small)
